# Hugging Face username (string). Es la ÚNICA credencial obligatoria para enviar.
HF_USERNAME=talcalde

# URL pública de referencia para el leaderboard. La API NO la valida.
# Puede ser tu repo de GitHub o un Space público mínimo.
AGENT_CODE_URL=https://github.com/talcaldeg/gaia-agent

# Proveedor del modelo: gemini | groq | hf
MODEL_PROVIDER=gemini

# Key gratuita de Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Opcional: key de Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Opcional: token de Hugging Face (para MODEL_PROVIDER=hf)
HF_TOKEN=

# Opcional: fuerza un modelo específico, sobrescribe el default del proveedor
# MODEL_ID=

# Segundos de pausa entre preguntas (respeta rate limits gratuitos)
SLEEP_BETWEEN=2
